# GuestDesk email settings
# Copy to /etc/guestdesk.env and restart the service
#   sudo install -m 0640 -o root -g root guestdesk.env.sample /etc/guestdesk.env
#   sudo systemctl daemon-reload
#   sudo systemctl restart guestdesk

# Turn on/off sending
EMAIL_ENABLED=1

# Where to send (comma-separated)
# For testing, set to your address
ISSUE_RECIPIENTS=you@example.com
# For production, e.g.:
# ISSUE_RECIPIENTS=facilities@gracemarketplace.org,shelterops@gracemarketplace.org

# Who it's from (display name + address)
EMAIL_FROM="GuestDesk <no-reply@gracemarketplace.org>"

# SMTP settings — example for Gmail (use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_USE_TLS=1
SMTP_USE_SSL=0

# If you relay via a local MTA (e.g., Postfix), use instead:
# SMTP_HOST=127.0.0.1
# SMTP_PORT=25
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=0
# SMTP_USE_SSL=0
